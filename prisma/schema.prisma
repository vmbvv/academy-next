generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

model Restaurant {
  id           String             @id @default(auto()) @map("_id") @db.ObjectId
  address      RestaurantAddress
  borough      String
  cuisine      String
  grades       RestaurantGrade[]
  name         String
  restaurantId String             @map("restaurant_id")

  @@index([name])
  @@index([borough, cuisine])
  @@map("restaurants")
}

type RestaurantAddress {
  building String
  coord    Float[]
  street   String
  zipcode  String
}

type RestaurantGrade {
  date  DateTime
  grade String
  score Int?
}
